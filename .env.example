# ═══════════════════════════════════════════════
# ZIYOU Analytics — variáveis de ambiente
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env no repositório.
# ═══════════════════════════════════════════════

# ── Mercado Livre OAuth2
ML_CLIENT_ID=seu_client_id_aqui
ML_CLIENT_SECRET=seu_client_secret_aqui

# ── Cloudflare Pages (para deploy via wrangler)
CF_API_TOKEN=seu_token_cloudflare_aqui
CF_ACCOUNT_ID=seu_account_id_cloudflare_aqui

# ── Webhook de notificação (opcional)
# NOTIFY_URL=https://hooks.slack.com/services/...

# ════════════════════════════════════════════════
# CONFIGURAÇÃO NO GITHUB SECRETS
# (Settings → Secrets → Actions → New repository secret)
# ════════════════════════════════════════════════
#
# ML_CLIENT_ID       → app ID do Mercado Livre Developers
# ML_CLIENT_SECRET   → secret do app ML Developers
# ML_TOKENS_JSON     → conteúdo de ~/.mercado-livre-analytics/tokens.json
#                      (access_token + refresh_token + expires_at + user_id)
#
# CF_API_TOKEN       → Cloudflare API Token com permissão "Cloudflare Pages: Edit"
# CF_ACCOUNT_ID      → ID da conta Cloudflare (visível em cloudflare.com → lado direito)
#
# NOTIFY_URL         → (opcional) webhook para notificação após atualização

# ════════════════════════════════════════════════
# COMO OBTER ML_TOKENS_JSON
# ════════════════════════════════════════════════
#
#   1. Execute localmente: uv run auth_setup.py
#   2. Copie o conteúdo: cat ~/.mercado-livre-analytics/tokens.json
#   3. No GitHub: Settings → Secrets → ML_TOKENS_JSON → cole o conteúdo
#
# ════════════════════════════════════════════════
# COMO OBTER CF_API_TOKEN
# ════════════════════════════════════════════════
#
#   1. Acesse dash.cloudflare.com → My Profile → API Tokens
#   2. Create Token → Use template "Edit Cloudflare Pages"
#   3. Cole o token gerado no GitHub Secret CF_API_TOKEN
